{
  "appId": "com.gudangjateng.app",
  "appName": "GudangJateng",
  "webDir": "public",
  "server": {
    "url": "https://gudangjateng.web.id",
    "allowNavigation": [
      "gudangjateng.web.id"
    ]
  },
  "android": {
    "buildOptions": {
      "keystorePath": null,
      "keystorePassword": null,
      "keystoreAlias": null,
      "keystoreAliasPassword": null
    }
  },
  "plugins": {
    "SplashScreen": {
      "launchShowDuration": 1000,
      "launchAutoHide": true,
      "backgroundColor": "#FFFFFF",
      "androidScaleType": "CENTER_INSIDE",
      "showSpinner": false
    }
  }
}
